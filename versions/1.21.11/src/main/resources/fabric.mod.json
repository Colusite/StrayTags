{
  "schemaVersion": 1,
  "id": "straytags",
  "version": "${version}",
  "name": "StrayTags",
  "description": "Tired of clan leaders changing their tag clan tag colour every 5 minutes?",
  "authors": [
    "Colusite"
  ],
  "license": "MIT",
  "icon": "assets/straytags/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "io.github.colusite.straytags.client.StrayTagsClient"
    ],
    "modmenu": [
      "io.github.colusite.straytags.client.modmenu.StrayTagsModMenuIntegration"
    ]
  },
  "mixins": [
    "straytags.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": ">=0.100.0"
  },
  "suggests": {
    "cloth-config": "*",
    "modmenu": "*"
  }
}